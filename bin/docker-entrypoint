#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ] || [ "${LD_PRELOAD}" = "libjemalloc.so.2" ]; then
  JEMALLOC=$(find /usr/lib -name 'libjemalloc.so.2' -print -quit 2>/dev/null || true)
  if [ -n "${JEMALLOC}" ]; then
    export LD_PRELOAD="${JEMALLOC}"
  fi
fi

prepare_db() {
  echo "[entrypoint] Preparing database (RAILS_ENV=${RAILS_ENV:-development})..."
  ./bin/rails db:prepare
}

# Only the web server owns migrations to avoid ConcurrentMigrationError with sidekiq.
case "${1}" in
  ./bin/rails|bin/rails)
    if [ "${2}" = "server" ]; then
      prepare_db
    elif [ "${2}" = "ingest:run" ]; then
      # Ingest assumes schema exists; create DB if needed without fighting web.
      ./bin/rails db:prepare
    fi
    ;;
  bundle)
    if [ "${2}" = "exec" ] && [ "${3}" = "rspec" ]; then
      prepare_db
    fi
    ;;
esac

exec "${@}"
