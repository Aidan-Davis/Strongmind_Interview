# Copy to .env for local overrides (optional; Compose has defaults).
# docker compose reads .env automatically for variable substitution.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=strongmind_interview_development

REDIS_URL=redis://redis:6379/0

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
AWS_ENDPOINT=http://minio:9000
AWS_BUCKET=github-ingest

SECRET_KEY_BASE=development_secret_key_base_for_local_docker_only_not_for_prod
